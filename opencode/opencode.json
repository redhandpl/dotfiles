{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-antigravity-auth@latest",
    "cc-safety-net",
    "@hoangp8/opencode-plugin-editor-diff@0.1.1",
    "opencode-mermaid-renderer@0.0.1"
  ],
  "provider": {
    "lmstudio-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      },
      "models": {
        "zai-org/GLM-4.7-Flash": {
          "name": "GLM-4.7-Flash (local)",
          "options": {
            "defaultGenerationOptions": {
              "max_tokens": 35000,
              "temperature": 0.7,
              "topK": 20,
              "repeatPenalty": 1.5,
              "topP": 0.95,
              "minP": 0.01
            }
          }
        },
        "Qwen/Qwen3.5-35B-A3B": {
          "name": "Qwen3.5-35B-A3B (local)",
          "options": {
            "defaultGenerationOptions": {
              "max_tokens": 35000,
              "temperature": 0.7,
              "topK": 20,
              "repeatPenalty": 1.5,
              "topP": 0.95,
              "minP": 0.01
            }
          }
        }
      }
    },
    "lmstudio-remote": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (remote)",
      "options": {
        "baseURL": "http://172.16.1.88:1234/v1"
      },
      "models": {
        "zai-org/GLM-4.7-Flash": {
          "name": "GLM-4.7-Flash (remote)",
          "options": {
            "defaultGenerationOptions": {
              "max_tokens": 35000,
              "temperature": 0.7,
              "topK": 20,
              "repeatPenalty": 1.5,
              "topP": 0.95,
              "minP": 0.01
            }
          }
        },
        "Qwen/Qwen3.5-35B-A3B": {
          "name": "Qwen3.5-35B-A3B (remote)",
          "options": {
            "defaultGenerationOptions": {
              "max_tokens": 35000,
              "temperature": 0.7,
              "topK": 20,
              "repeatPenalty": 1.5,
              "topP": 0.95,
              "minP": 0.01
            }
          }
        }
      }
    },
    "google": {
      "models": {
        "antigravity-gemini-3-pro": {
          "name": "Gemini 3 Pro (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "thinkingLevel": "low"
            },
            "high": {
              "thinkingLevel": "high"
            }
          }
        },
        "antigravity-gemini-3.1-pro": {
